{
  "name": "monkeyscloud/monkeyslegion-env",
  "description": "Environment variable management library for PHP applications",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\Env\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MonkeysLegion\\Env\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.4",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.12"
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-html coverage",
    "analyse": "phpstan analyse src --level=max",
    "cs-fix": "php-cs-fixer fix src",
    "ci": [
      "@analyse",
      "@test"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
